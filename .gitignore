# ============================================================
# DynastyVR — Unreal Engine 5 .gitignore
# ============================================================

# ============ UE5 Generated ============
/Binaries/
/Intermediate/
/DerivedDataCache/
/Saved/
/Logs/

# ============ Build Artifacts ============
/*.sln
/enc temp/
/obj/

# ============ IDEs ============
.vs/
.vscode/
.idea/
*.suo
*.user
*.userprefs
*.sln.docstates
*.VC.db
*.VC.opendb
*.opensdf
*.sdf
*.cachefile
ipch/

# ============ OS Generated ============
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ============ Unreal Engine Specific ============
/Content/Developers/
/Content/AAA/
*.log
*.tmp
*.bak
*.swp
*.stackdump

# ============ Compiled Objects ============
*.o
*.obj
*.exe
*.dll
*.so
*.dylib
*.pdb

# ============ Plugin Build Output ============
Plugins/*/Binaries/
Plugins/*/Intermediate/
Plugins/*/DerivedDataCache/

# ============ Cesium for Unreal ============
# Cesium runtime caches
**/CesiumIonToken*.ini
*.ion-token
CesiumCache/

# ============ Crash Reports ============
/CrashReports/

# ============ Large Asset Source Files (keep UE5 assets) ============
# Uncomment to ignore source art files:
# *.blend
# *.fbx
# *.obj
# *.psd
# *.tga

# ============ Git LFS ============
# UE5 uses Git LFS for large assets
*.uasset filter=lfs diff=lfs merge=lfs -text
*.umap filter=lfs diff=lfs merge=lfs -text
